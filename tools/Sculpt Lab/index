<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Sculpt Lab | ells79.me</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@300;500&display=swap" rel="stylesheet">
    <style>
        :root { 
            --bg: #2a2a2a; /* 影棚灰色背景 */
            --accent: #ff4444; 
            --text: #eee; 
        }
        body { margin: 0; background: var(--bg); overflow: hidden; font-family: 'Space Grotesk', sans-serif; color: var(--text); touch-action: none; }
        canvas { display: block; }

        /* UI Overlay 层 */
        #ui-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; }
        
        #tray {
            position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
            display: flex; gap: 15px; pointer-events: auto; padding: 10px;
            background: rgba(0,0,0,0.2); border-radius: 20px; backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1); transition: opacity 0.5s;
        }
        .tray-item {
            width: 60px; height: 60px; border-radius: 12px;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.3s; color: #888;
        }
        .tray-item span { font-size: 20px; }
        .tray-item label { font-size: 8px; font-family: 'JetBrains Mono'; margin-top: 4px; }
        .tray-item:hover { background: rgba(255,255,255,0.1); color: #fff; }
        .tray-item.active { background: #fff; color: #000; }

        #countdown {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            font-size: 100px; font-family: 'JetBrains Mono'; color: white; display: none; z-index: 20;
            text-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        #hud {
            position: absolute; top: 40px; width: 100%; text-align: center;
            font-family: 'JetBrains Mono'; font-size: 10px; color: #888; letter-spacing: 2px;
        }
        
        #pressure-gauge {
            position: absolute; left: 30px; top: 50%; transform: translateY(-50%);
            width: 4px; height: 150px; background: rgba(0,0,0,0.3); border-radius: 2px;
            display: none;
        }
        #pressure-fill {
            position: absolute; bottom: 0; width: 100%; background: white;
            height: 0%; transition: height 0.1s; border-radius: 2px;
        }

        #result-screen {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85);
            display: none; flex-direction: column; justify-content: center; align-items: center;
            z-index: 100; text-align: center;
        }
        #res-status { font-family: 'JetBrains Mono'; font-size: 14px; letter-spacing: 5px; color: #fff; margin-bottom: 20px; text-transform: uppercase; }
        #gallery-tag {
            background: white; color: black; padding: 20px; text-align: left;
            border-left: 5px solid var(--accent); max-width: 250px;
            box-shadow: 10px 10px 0px rgba(0,0,0,0.2); transform: rotate(-1deg);
        }
        #gallery-tag h3 { font-family: 'JetBrains Mono'; font-size: 14px; margin: 0 0 10px 0; border-bottom: 1px solid #ddd; padding-bottom: 5px; }
        #gallery-tag p { font-size: 10px; margin: 5px 0; color: #333; line-height: 1.4; }
        
        .actions { display: flex; gap: 10px; margin-top: 40px; }
        .btn-action {
            padding: 12px 25px; border: 1px solid rgba(255,255,255,0.3); border-radius: 30px;
            cursor: pointer; font-size: 10px; text-transform: uppercase; pointer-events: auto;
            color: #888; transition: all 0.3s;
        }
        .btn-action:hover { background: #fff; color: #000; border-color: #fff; }

        #certificate-modal {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.96); display: none; justify-content: center; align-items: center;
            z-index: 200; pointer-events: auto;
        }
        #certificate-card {
            width: 320px; height: 600px; background: #fff; color: #000;
            padding: 30px; box-sizing: border-box; position: relative;
            display: flex; flex-direction: column; align-items: center;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5);
        }
        #cert-silhouette { width: 100%; height: 220px; margin: 20px 0; display: flex; align-items: center; justify-content: center; }
        #cert-silhouette canvas { width: 160px !important; height: 200px !important; background: transparent; }
        .cert-header { font-family: 'JetBrains Mono'; font-size: 9px; text-transform: uppercase; border-bottom: 1px solid #eee; width: 100%; padding-bottom: 8px; margin-bottom: 15px;}
        .cert-footer { font-family: 'JetBrains Mono'; font-size: 8px; color: #999; text-align: left; width: 100%; margin-top: auto; line-height: 1.6; }
        .cert-id { position: absolute; bottom: 30px; right: 20px; font-family: 'JetBrains Mono'; font-size: 7px; opacity: 0.2; transform: rotate(90deg); transform-origin: right bottom; }
        
        .close-cert-btn { 
            width: 100%; margin-top: 15px; border: 1px solid #ddd; padding: 10px; 
            text-align: center; font-family: 'JetBrains Mono'; font-size: 10px; 
            cursor: pointer; transition: 0.3s; color: #666;
        }
        .close-cert-btn:hover { background: #000; color: #fff; border-color: #000; }
        
        .sarcastic-stats { width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-top: 10px; font-size: 8px; font-family: 'JetBrains Mono'; color: #444; }
    </style>
</head>
<body>

    <div id="ui-layer">
        <div id="hud">SYSTEM: SCULPT_LAB_V2.5 // STUDIO_MODE: ON</div>
        
        <div id="pressure-gauge">
            <div id="pressure-fill"></div>
        </div>

        <div id="tray">
            <div class="tray-item" onclick="selectType('constipation', this)"><span>🪨</span><label>LV1:HARD</label></div>
            <div class="tray-item" onclick="selectType('dog', this)"><span>💩</span><label>LV2:DOG</label></div>
            <div class="tray-item" onclick="selectType('sticky', this)"><span>🍮</span><label>LV3:STICKY</label></div>
        </div>
        <div id="countdown"></div>
    </div>

    <div id="result-screen">
        <h2 id="res-status"></h2>
        <div id="gallery-tag">
            <h3 id="work-title">Untitled</h3>
            <p><strong>Artist:</strong> ells (ARCHIVE_V2.5)</p>
            <p><strong>Medium:</strong> Studio Capture</p>
            <p id="work-desc"></p>
        </div>
        <div class="actions">
            <div class="btn-action" onclick="showCertificate()">View Certificate</div>
            <div class="btn-action" onclick="resetGame()">Retry</div>
        </div>
    </div>

    <!-- 证书弹窗 -->
    <div id="certificate-modal">
        <div id="certificate-card">
            <div class="cert-header">ells79.me // Creative Proof of Concept</div>
            <h1 style="margin:0; font-size: 18px; width: 100%; text-align: left; letter-spacing: -0.5px;">Fossil Certificate</h1>
            
            <div id="cert-silhouette">
                <canvas id="sil-canvas"></canvas>
            </div>

            <div class="sarcastic-stats">
                <div>KPI_REACHED: 100%</div>
                <div>CLIENT_SAT: 92%</div>
                <div>AESTHETIC_ROI: HIGH</div>
                <div>BUDGET_LOSS: MIN</div>
                <div>EGO_BALANCE: PASS</div>
                <div>FEEDBACK_LOOPS: 0</div>
            </div>

            <div class="cert-footer">
                <p><strong>OBJECT_TYPE:</strong> <span id="cert-obj-name">--</span></p>
                <p><strong>CREATION_DATE:</strong> <span id="cert-time">--</span></p>
                <p style="margin-top: 10px; border-top: 1px solid #eee; padding-top: 10px;">"在旋转的不安中，我们通过 5.0 秒的对抗，留下了一份符合市场预期的数字化残骸。"</p>
            </div>
            
            <div class="close-cert-btn" onclick="hideCertificate()">[ BACK TO GALLERY ]</div>
            <div class="close-cert-btn" style="margin-top: 5px;" onclick="resetGame()">[ START NEW BRIEF ]</div>

            <div class="cert-id" id="cert-id-tag">ARCHIVE_ID: 000-000</div>
        </div>
    </div>

    <script>
        let scene, camera, renderer, clay, wheelBase, flower, clock, galleryLight;
        let keyLight, fillLight, rimLight; // 影棚三点布光
        let gameState = 'MENU'; 
        let touchPoints = []; 
        let userPressure = 0; 
        let currentRadii = []; 
        let gameTime = 0;
        let config = null;
        let audioCtx;

        const POINTS_COUNT = 40; 
        const GAME_DURATION = 5.0; 

        const TYPES = {
            constipation: { 
                color: 0x8c8c8c, sensitivity: 0.04, drift: 0.005, 
                name: 'HARD_ROCK', adjectives: ["Brutalist", "Rigid", "Legacy"],
                initFunc: (t) => 1.2 + Math.cos(t * Math.PI) * 0.15 
            },
            dog: { 
                color: 0x6e5a4b, sensitivity: 0.07, drift: 0.012, 
                name: 'DOG_SHIT', adjectives: ["Daily", "Fragile", "Messy"],
                initFunc: (t) => (Math.sin(t * 10) * 0.1 + 0.9) * (1 - t * 0.8) 
            },
            sticky: { 
                color: 0x5a4a3a, sensitivity: 0.14, drift: 0.025, 
                name: 'STICKY_RICE', adjectives: ["Viscous", "Chaos", "Adaptive"],
                initFunc: (t) => 1.0 + Math.sin(t * 3) * 0.25 
            }
        };

        const BLACK_WORDS = ["Post-Truth", "Revenue", "Synergy", "Framework", "Paradigm", "Heuristic", "Derivative"];
        const NOUNS = ["Artifact", "Landscape", "Echo", "Void", "Structure", "Flow", "Impact"];

        function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x2a2a2a); // 灰色影棚背景

            camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(0, 3, 10);
            camera.lookAt(0, 0.5, 0);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.shadowMap.enabled = true;
            document.body.appendChild(renderer.domElement);

            // --- 影棚布光系统 (Studio Lighting) ---
            
            // 1. 主光 (Key Light): 强调体积和明暗交界
            keyLight = new THREE.SpotLight(0xffffff, 1.2);
            keyLight.position.set(5, 10, 5);
            keyLight.angle = 0.5;
            keyLight.penumbra = 0.5;
            keyLight.castShadow = true;
            scene.add(keyLight);

            // 2. 补光 (Fill Light): 柔和阴影部分
            fillLight = new THREE.PointLight(0xffffff, 0.4);
            fillLight.position.set(-5, 2, 2);
            scene.add(fillLight);

            // 3. 轮廓光 (Rim Light): 勾勒边缘线，增强分离感
            rimLight = new THREE.DirectionalLight(0xffffff, 1.5);
            rimLight.position.set(-5, 5, -5);
            scene.add(rimLight);

            // 环境光
            const ambient = new THREE.AmbientLight(0xffffff, 0.2);
            scene.add(ambient);

            // 画廊射灯 (结算时开启)
            galleryLight = new THREE.SpotLight(0xffffff, 0);
            galleryLight.position.set(0, 10, 2);
            scene.add(galleryLight);

            // 陶轮托盘底座 (Pottery Wheel Plate)
            const plateGeo = new THREE.CylinderGeometry(3.0, 3.2, 0.4, 64);
            const plateMat = new THREE.MeshPhysicalMaterial({ 
                color: 0xcccccc, 
                metalness: 0.1, 
                roughness: 0.8,
                clearcoat: 0.1
            });
            wheelBase = new THREE.Mesh(plateGeo, plateMat);
            wheelBase.position.y = -2.5;
            wheelBase.receiveShadow = true;
            scene.add(wheelBase);

            // 底座阴影平面
            const groundGeo = new THREE.PlaneGeometry(20, 20);
            const groundMat = new THREE.ShadowMaterial({ opacity: 0.15 });
            const ground = new THREE.Mesh(groundGeo, groundMat);
            ground.rotation.x = -Math.PI / 2;
            ground.position.y = -3.5;
            ground.receiveShadow = true;
            scene.add(ground);

            clock = new THREE.Clock();

            window.addEventListener('mousedown', onMouseDown);
            window.addEventListener('mousemove', onMouseMove);
            window.addEventListener('mouseup', onMouseUp);
            window.addEventListener('touchstart', onTouchStart, {passive: false});
            window.addEventListener('touchmove', onTouchMove, {passive: false});
            window.addEventListener('touchend', onTouchEnd);
            window.addEventListener('resize', onResize);
        }

        function onMouseDown(e) { touchPoints = [{x: (e.clientX/window.innerWidth)*2-1, y: -(e.clientY/window.innerHeight)*2+1}]; resumeAudio(); }
        function onMouseMove(e) { if(touchPoints.length > 0) touchPoints[0] = {x: (e.clientX/window.innerWidth)*2-1, y: -(e.clientY/window.innerHeight)*2+1}; }
        function onMouseUp() { touchPoints = []; }
        function onTouchStart(e) { resumeAudio(); updateTouches(e); e.preventDefault(); }
        function onTouchMove(e) { updateTouches(e); e.preventDefault(); }
        function onTouchEnd(e) { updateTouches(e); }
        function updateTouches(e) {
            touchPoints = Array.from(e.touches).map(t => ({
                x: (t.clientX / window.innerWidth) * 2 - 1,
                y: -(t.clientY / window.innerHeight) * 2 + 1
            }));
        }

        function resumeAudio() { if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume(); }

        function selectType(type, el) {
            if (gameState !== 'MENU') return;
            config = TYPES[type];
            document.querySelectorAll('.tray-item').forEach(i => i.classList.remove('active'));
            el.classList.add('active');
            
            gameState = 'COUNTDOWN';
            document.getElementById('tray').style.opacity = 0;
            document.getElementById('tray').style.pointerEvents = 'none';
            
            const cd = document.getElementById('countdown');
            cd.style.display = 'block';
            let c = 3;
            cd.innerText = c;
            if (!audioCtx) initAudio();
            const timer = setInterval(() => {
                c--;
                if(c > 0) cd.innerText = c;
                else {
                    clearInterval(timer);
                    cd.style.display = 'none';
                    startChallenge();
                }
            }, 800);
        }

        function startChallenge() {
            gameState = 'PLAYING';
            gameTime = 0;
            userPressure = 0;
            document.getElementById('hud').innerText = "STUDIO // LIVE_SCULPTING";
            document.getElementById('pressure-gauge').style.display = 'block';
            currentRadii = [];
            for (let i = 0; i < POINTS_COUNT; i++) {
                currentRadii.push(config.initFunc(i / (POINTS_COUNT - 1)));
            }
            updateClayMesh();
        }

        function updateClayMesh() {
            if(clay) scene.remove(clay);
            const pts = [];
            for(let i=0; i<POINTS_COUNT; i++) {
                pts.push(new THREE.Vector2(currentRadii[i], (i - POINTS_COUNT/2) * 0.12));
            }
            const geo = new THREE.LatheGeometry(pts, 64);
            const mat = new THREE.MeshPhysicalMaterial({ 
                color: config.color, 
                roughness: 0.65, // 略带磨砂感的陶土
                metalness: 0.05,
                clearcoat: 0.05, // 极其微弱的釉面感
                flatShading: false
            });
            clay = new THREE.Mesh(geo, mat);
            clay.position.y = 0.1; 
            clay.castShadow = true;
            clay.receiveShadow = true;
            scene.add(clay);
        }

        function endGame(win, reason) {
            gameState = 'END';
            document.getElementById('pressure-gauge').style.display = 'none';
            document.getElementById('hud').innerText = "V2.5 // CAPTURE_COMPLETE";
            
            const statusEl = document.getElementById('res-status');
            const galleryEl = document.getElementById('gallery-tag');

            if (win) {
                const adj = config.adjectives[Math.floor(Math.random()*config.adjectives.length)];
                const black = BLACK_WORDS[Math.floor(Math.random()*BLACK_WORDS.length)];
                const noun = NOUNS[Math.floor(Math.random()*NOUNS.length)];
                const title = `${adj} ${black} ${noun}`;
                
                document.getElementById('work-title').innerText = title;
                document.getElementById('work-desc').innerText = `捕捉到的 5 秒数字残余。不仅是形状，更是那一刻对抗离心力的审美意志。`;
                
                statusEl.innerText = "CRAFT SUCCESSFUL";
                statusEl.style.color = "#fff";
                galleryEl.style.background = "#fff";
                galleryEl.style.color = "#000";

                // 变成完美的精瓷质感
                clay.material.color.set(0xffffff);
                clay.material.roughness = 0.1;
                clay.material.clearcoat = 1.0;
                
                // 聚焦射灯
                galleryLight.intensity = 2.0;
                galleryLight.target = clay;
                rimLight.intensity = 2.5; // 增强轮廓线
                
                const flowerGroup = new THREE.Group();
                const pMat = new THREE.MeshBasicMaterial({ color: 0xff4444 });
                for(let i=0; i<8; i++){
                    const p = new THREE.Mesh(new THREE.SphereGeometry(0.2, 8, 8), pMat);
                    p.scale.set(1.8, 0.4, 1);
                    p.position.set(Math.cos(i*0.8)*0.25, 0, Math.sin(i*0.8)*0.25);
                    p.rotation.y = i*0.8;
                    flowerGroup.add(p);
                }
                flower = flowerGroup; flower.position.y = 2.4;
                scene.add(flower);
                document.getElementById('result-screen').style.display = 'flex';
            } else {
                statusEl.innerText = "CRAFT COLLAPSED";
                statusEl.style.color = "#ff4444";
                document.getElementById('result-screen').style.display = 'flex';
                document.getElementById('work-title').innerText = "Session Lost";
                document.getElementById('work-desc').innerText = reason;
                galleryEl.style.background = "#300";
                galleryEl.style.color = "#fff";
            }
        }

        function showCertificate() {
            const modal = document.getElementById('certificate-modal');
            const canvas = document.getElementById('sil-canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = 300;
            canvas.height = 360;
            modal.style.display = 'flex';
            ctx.clearRect(0,0,300,360);
            ctx.fillStyle = '#000';
            ctx.beginPath();
            const centerX = 150;
            const startY = 320;
            const scaleX = 40;
            const scaleY = 6.5;
            for(let i=0; i<POINTS_COUNT; i++) {
                const r = currentRadii[i] * scaleX;
                const y = startY - (i * scaleY);
                if(i===0) ctx.moveTo(centerX + r, y);
                else ctx.lineTo(centerX + r, y);
            }
            ctx.lineTo(centerX, startY - (POINTS_COUNT-1) * scaleY);
            for(let i=POINTS_COUNT-1; i>=0; i--) {
                const r = currentRadii[i] * scaleX;
                const y = startY - (i * scaleY);
                ctx.lineTo(centerX - r, y);
            }
            ctx.closePath();
            ctx.fill();
            document.getElementById('cert-obj-name').innerText = config.name;
            document.getElementById('cert-time').innerText = new Date().toLocaleString();
            document.getElementById('cert-id-tag').innerText = "ARCHIVE_ID: " + Math.random().toString(36).substr(2, 6).toUpperCase();
        }

        function hideCertificate() { document.getElementById('certificate-modal').style.display = 'none'; }

        function resetGame() {
            if(clay) scene.remove(clay);
            if(flower) scene.remove(flower);
            galleryLight.intensity = 0;
            rimLight.intensity = 1.5;
            gameState = 'MENU';
            document.getElementById('result-screen').style.display = 'none';
            document.getElementById('tray').style.opacity = 1;
            document.getElementById('tray').style.pointerEvents = 'auto';
            document.getElementById('hud').innerText = "SYSTEM: SCULPT_LAB_V2.5 // STUDIO_MODE: ON";
            hideCertificate();
        }

        function onResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function initAudio() {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const melody = [392, 440, 494, 392, 440, 494, 349, 392, 440, 330, 349, 392];
            let step = 0;
            setInterval(() => {
                if (gameState === 'PLAYING') {
                    const osc = audioCtx.createOscillator();
                    const gain = audioCtx.createGain();
                    osc.type = 'square';
                    osc.frequency.setValueAtTime(melody[step % melody.length], audioCtx.currentTime);
                    gain.gain.setValueAtTime(0.04, audioCtx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.3);
                    osc.connect(gain); gain.connect(audioCtx.destination);
                    osc.start(); osc.stop(audioCtx.currentTime + 0.3);
                    step++;
                }
            }, 400); 
        }

        function animate() {
            requestAnimationFrame(animate);
            const dt = clock.getDelta();
            
            if (wheelBase) wheelBase.rotation.y += (gameState === 'PLAYING' ? 0.22 : 0.05);

            if (gameState === 'PLAYING' && clay) {
                gameTime += dt;
                clay.rotation.y += 0.45; 

                const isTouching = touchPoints.length > 0;
                if (isTouching) userPressure = Math.min(1.0, userPressure + dt * 2.8);
                else userPressure = Math.max(0, userPressure - dt * 2.0);
                document.getElementById('pressure-fill').style.height = (userPressure * 100) + '%';

                let hasCollapsed = false;
                let reason = "";
                const shapingTouch = touchPoints.length > 1 ? touchPoints[1] : (isTouching ? touchPoints[0] : null);

                for(let i=0; i<POINTS_COUNT; i++) {
                    const h = (i / (POINTS_COUNT - 1));
                    const drift = config.drift * (1.1 + h * 1.8);
                    currentRadii[i] += drift * (1.1 - userPressure * 1.1); 

                    if(shapingTouch) {
                        const touchH = (shapingTouch.y * 0.8 + 0.5); 
                        const distToTouch = Math.abs(h - touchH);
                        if(distToTouch < 0.28) {
                            const influence = 1.0 - (distToTouch / 0.28);
                            const targetR = Math.abs(shapingTouch.x) * 4.5;
                            currentRadii[i] = currentRadii[i] * (1 - influence * 0.25) + targetR * (influence * 0.25);
                        }
                    }

                    if(currentRadii[i] < 0.08) { hasCollapsed = true; reason = "太用力了。理想由于过度修饰而破碎。"; }
                    if(currentRadii[i] > 4.2) { hasCollapsed = true; reason = "失去控制。创意在放任中坍塌。"; }
                }

                updateClayMesh();
                if (hasCollapsed) endGame(false, reason);
                if (gameTime > GAME_DURATION) endGame(true); 
            }
            if (gameState === 'END' && clay) {
                clay.rotation.y += 0.01;
                if(flower) flower.rotation.y += 0.02;
            }
            renderer.render(scene, camera);
        }

        init();
        animate();
    </script>
</body>
</html>
